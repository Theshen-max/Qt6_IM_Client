# 忽略 Qt 独有的构建产物
build/
.qmake.stash
Makefile*
ui_*.h         # 忽略 uic 工具自动生成的 UI 头文件
moc_*.cpp      # 忽略 moc 工具自动生成的元对象代码
qrc_*.cpp      # 忽略 rcc 工具生成的资源代码
res/
static/

# ==========================================
# 如何指定过滤特定的子目录？(假设以下目录存在)
# ==========================================



# 4. 忽略特定后缀的设计文件
*.ui
*.qmlc         # 编译后的 QML 缓存文件
*.jsc
*.qrc

.git/
.svn/